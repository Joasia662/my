Sub GenerujHasla()
    Dim tbl As ListObject
    Dim ws As Worksheet
    Dim i As Long
    Dim colPassword As Long
    
    ' Find the worksheet containing the AdminSetUp table
    Dim found As Boolean
    found = False
    
    For Each ws In ThisWorkbook.Worksheets
        For Each tbl In ws.ListObjects
            If tbl.Name = "AdminSetUp" Then
                found = True
                Exit For
            End If
        Next tbl
        If found Then Exit For
    Next ws
    
    If Not found Then
        MsgBox "Table 'AdminSetUp' not found!", vbExclamation
        Exit Sub
    End If
    
    ' Find the Password column index
    colPassword = 0
    Dim col As ListColumn
    For Each col In tbl.ListColumns
        If col.Name = "Password" Then
            colPassword = col.Index
            Exit For
        End If
    Next col
    
    If colPassword = 0 Then
        MsgBox "Column 'Password' not found!", vbExclamation
        Exit Sub
    End If
    
    ' Define character set for password generation
    Dim znaki As String
    znaki = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%"
    
    Randomize
    
    ' Generate a 10-character password for each row and write it to the Password column
    Dim r As ListRow
    Dim haslo As String
    Dim j As Integer
    
    For Each r In tbl.ListRows
        haslo = ""
        For j = 1 To 10
            haslo = haslo & Mid(znaki, Int(Rnd() * Len(znaki)) + 1, 1)
        Next j
        r.Range(colPassword).Value = haslo
    Next r
    
    MsgBox "Passwords generated successfully!", vbInformation
End Sub
